# Database Protection
ALLOW_PRODUCTION_DB=false
DB_PATH=tasi_ledger_test.db

# Production DB Gate (Phase 6T)
PRODUCTION_DB_PATH=
ENABLE_PRODUCTION_DB_READONLY_GATE=false
PRODUCTION_DB_READONLY_REQUIRED=true

# Authentication
# Replace this with a secure random key for actual usage, kept generic for sandbox.
JWT_SECRET_KEY=change_me_for_sandbox
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Client Configuration
VITE_API_URL=/api

# Integrations (Phase 4A Smoke Tests)
# DO NOT ADD REAL KEYS HERE IN SANDBOX MODE
# CLAUDE_API_KEY=
# TWELVEDATA_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_SMOKE_TEST_MODEL=claude-haiku-4-5-20251001
TELEGRAM_BOT_TOKEN=
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
AUTHORIZED_USER_IDS=
ENABLE_API_SMOKE_TESTS=false
ENABLE_ALERT_SCHEDULER=false
ALERT_SCHEDULER_DRY_RUN_ONLY=true
ALERT_TEST_INTERVAL_SECONDS=300

ENABLE_MARKET_DATA_SMOKE_TESTS=false
MARKET_DATA_PROVIDER=mock
TWELVEDATA_API_KEY=
MARKET_DATA_SAMPLE_TICKER=2222.SR

ENABLE_OHLCV_DIAGNOSTICS=false
OHLCV_SAMPLE_TICKER=2222.SR
OHLCV_LOOKBACK_DAYS=180
OHLCV_MIN_REQUIRED_BARS=120

ENABLE_PROVIDER_COVERAGE_SCAN=false
PROVIDER_COVERAGE_LIMIT=80
PROVIDER_COVERAGE_LOOKBACK_DAYS=180
PROVIDER_COVERAGE_MIN_REQUIRED_BARS=120

ENABLE_LIVE_ANALYZE_PREVIEW=false
LIVE_ANALYZE_PROVIDER=yfinance
LIVE_ANALYZE_LOOKBACK_DAYS=180
LIVE_ANALYZE_MIN_REQUIRED_BARS=120

ENABLE_LIVE_SCOUT_PREVIEW=false
LIVE_SCOUT_PROVIDER=yfinance
LIVE_SCOUT_LOOKBACK_DAYS=180
LIVE_SCOUT_MIN_REQUIRED_BARS=120
LIVE_SCOUT_LIMIT=10

SAHMK_API_KEY=
TRADINGVIEW_API_KEY=

ENABLE_TELEGRAM_DRY_RUN=true
# Phase 7A — Controlled manual test-send gates.
# ALL THREE must be set to their required values to allow a network call:
#   ENABLE_TELEGRAM_TEST_SEND=true   (gate 1)
#   ENABLE_TELEGRAM_SEND=true        (gate 2)
#   ENABLE_ALERT_SCHEDULER=false     (gate 3 — scheduler must remain OFF)
# Default (safe): all sends disabled.
ENABLE_TELEGRAM_SEND=false
ENABLE_TELEGRAM_TEST_SEND=false

# ============================================================================
# GHBS Trading — TASI Quant Command Center — PRIVATE LIVE PROFILE (example)
# ============================================================================
# Copy the values you need into the REAL .env on the VPS (never commit .env).
# This file documents how to enable Private Live Mode. It contains NO secrets.
#
# HARD INVARIANTS — do not change these to enable dangerous behavior:
#   ALLOW_PRODUCTION_DB=false            (production DB writes stay impossible)
#   PRODUCTION_DB_READONLY_REQUIRED=true (read-only gate remains required)
#   No broker/trade execution exists in this app.
#   Public exposure is blocked at the network layer (Tailscale-only).
# ============================================================================

# ---- Database: keep the sandbox/test ledger; never enable prod writes ----
ALLOW_PRODUCTION_DB=false
DB_PATH=tasi_ledger_test.db
ENABLE_PRODUCTION_DB_READONLY_GATE=false
PRODUCTION_DB_READONLY_REQUIRED=true

# ---- PRIVATE LIVE MODE: market data + read-only previews ----
ENABLE_API_SMOKE_TESTS=true
ENABLE_MARKET_DATA_SMOKE_TESTS=true
ENABLE_PROVIDER_COVERAGE_SCAN=true
ENABLE_OHLCV_DIAGNOSTICS=true
ENABLE_LIVE_ANALYZE_PREVIEW=true
ENABLE_LIVE_SCOUT_PREVIEW=true

# ---- Telegram (manual + test-send). Sending stays gated by these flags ----
ENABLE_TELEGRAM_DRY_RUN=true
ENABLE_TELEGRAM_SEND=true
ENABLE_TELEGRAM_TEST_SEND=true
# Provide the real values ONLY in the VPS .env, never here:
# TELEGRAM_BOT_TOKEN=      (or TELEGRAM_TOKEN alias)
# TELEGRAM_CHAT_ID=
# AUTHORIZED_USER_IDS=

# ---- Provider API keys (set real values only in VPS .env) ----
# TWELVEDATA_API_KEY=
# SAHMK_API_KEY=
# TRADINGVIEW_API_KEY=
# ANTHROPIC_API_KEY=

# ---- AUTOMATED ALERT MODE (optional): enable the scheduler intentionally ----
# ENABLE_ALERT_SCHEDULER=true
# ALERT_SCHEDULER_DRY_RUN_ONLY=true    # set to false only for approved real sends

# ---- To return to LOCKED / MAINTENANCE mode, set every ENABLE_* above to false ----
